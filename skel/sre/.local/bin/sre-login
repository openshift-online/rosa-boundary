#!/bin/bash
# sre-login — log into a cluster via ocm backplane.
#
# Resolves the cluster argument by searching OCM by name, then ID, then
# external_id. On successful login, clears the session sentinel so future
# shell entries do not skip auto-login.
#
# Supports CLUSTER_AUTH_METHOD:
#   backplane (default): uses ocm backplane login
#   proxy: skips login (kube-proxy sidecar handles auth)
#
# Ported from openshift/ocm-container, adapted for sre user.

# Resolve cluster argument — search by name, then ID, then external_id
get_cluster_json() {
    local ocmjson total

    # Validate cluster argument: allow alphanumeric, hyphens, underscores, dots
    if ! [[ "${1}" =~ ^[a-zA-Z0-9._-]+$ ]]; then
        echo "Invalid cluster identifier: \"${1}\"" >&2
        return 1
    fi

    # Try by name
    ocmjson=$(ocm get clusters --parameter search="name='${1}'")
    total=$(jq --raw-output ".total" <<<"${ocmjson}")

    if [ "${total}" -eq 1 ]; then
        jq ".items[0]" <<<"${ocmjson}"
        return
    elif [ "${total}" -gt 1 ]; then
        echo "There is more than one cluster with that name." >&2
        echo "Run sre-login again using an ID from below." >&2
        echo >&2
        jq --raw-output '.items[] | [.id, .name, .display_name] | @csv' <<<"${ocmjson}" |
            tr --delete '"' |
            column -N "ID,NAME,DISPLAY_NAME" -t -s "," >&2
        return 1
    fi

    # Try by ID
    ocmjson=$(ocm get clusters --parameter search="id='${1}'")
    total=$(jq --raw-output ".total" <<<"${ocmjson}")
    if [ "${total}" -eq 1 ]; then
        jq ".items[0]" <<<"${ocmjson}"
        return
    fi

    # Try by external ID
    ocmjson=$(ocm get clusters --parameter search="external_id='${1}'")
    total=$(jq --raw-output ".total" <<<"${ocmjson}")
    if [ "${total}" -eq 1 ]; then
        jq ".items[0]" <<<"${ocmjson}"
        return
    fi

    echo "Could not find a cluster with name, id or external id of \"${1}\"" >&2
    return 1
}

# Main execution — only runs when invoked directly, not when sourced.
sre_login_main() {
    set -euo pipefail

    # Proxy mode: no backplane login needed
    if [[ "${CLUSTER_AUTH_METHOD:-backplane}" == "proxy" ]]; then
        echo "Proxy sidecar mode: cluster access is provided by the kube-proxy sidecar."
        echo "No login required. Run 'oc get nodes' to verify connectivity."
        exit 0
    fi

    # Verify backplane is installed
    if ! ocm backplane version &>/dev/null; then
        echo "The OCM backplane plugin must be installed for automatic cluster login." >&2
        exit 1
    fi

    if [ -z "${1:-}" ]; then
        echo "Usage: sre-login <cluster-name-or-id>" >&2
        exit 1
    fi

    echo "Logging into cluster ${1}"

    local clusterjson cluster_id
    clusterjson=$(get_cluster_json "${1}")
    cluster_id=$(jq --raw-output '.id' <<<"${clusterjson}")

    # Login and clear sentinel on success. Use explicit if/else instead of
    # rc=$? which is dead code under set -e (failure exits before rc is set).
    if ocm backplane login "${cluster_id}"; then
        rm --force "${HOME}/.session/sre-login-attempted"
    else
        exit 1
    fi
}

# Guard: allow sourcing for tests without executing
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    sre_login_main "$@"
fi
