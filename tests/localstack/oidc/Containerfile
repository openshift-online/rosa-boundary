FROM python:3.11-slim

WORKDIR /app

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Install dependencies
COPY pyproject.toml .
RUN uv pip install --system --no-cache -r pyproject.toml

# Copy application
COPY mock_jwks.py .

# Expose port
EXPOSE 8080

# Run Flask server
CMD ["python", "mock_jwks.py"]
